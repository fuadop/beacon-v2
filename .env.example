# --- InfluxDB 3 Core ---
INFLUXDB_DATABASE=network_monitor
# Token for authenticating writes/queries against InfluxDB 3's HTTP API.
# Generate after first boot with: docker compose exec influxdb influxdb3 create token --admin
INFLUXDB_TOKEN=

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me

# --- Config API / Config Watcher / Trap Receiver ---
CONFIG_DB_PATH=/data/config.db
TRAPS_DB_PATH=/data/traps.db

# 32-byte key, hex-encoded (64 hex chars), used for AES-256-GCM credential encryption.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# How often (seconds) config-watcher polls SQLite for device/setting changes.
CONFIG_WATCHER_POLL_SECONDS=10

# Docker Compose service name of the telegraf container, used by config-watcher
# for `docker exec <name> kill -SIGHUP 1`.
TELEGRAF_CONTAINER_NAME=beacon-v2-telegraf-1
