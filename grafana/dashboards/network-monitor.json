        "widthMode": "auto",
        "name": "deviceForm",
        "elementValueChanged": "if (context.element.id === 'device_id') {\n  const id = context.element.value;\n  if (!id) {\n    return;\n  }\n  fetch(`http://localhost:8080/devices/${id}`)\n    .then((resp) => {\n      if (!resp.ok) {\n        throw new Error(`HTTP ${resp.status}`);\n      }\n      return resp.json();\n    })\n    .then((d) => {\n      context.panel.patchFormValue({\n        ip_address: d.ip_address || '',\n        hostname: d.hostname || '',\n        snmp_version: d.snmp_version || '',\n        group_name: d.group_name || '',\n        v3_user: d.v3_user || '',\n        v3_auth_protocol: d.v3_auth_protocol || '',\n        v3_priv_protocol: d.v3_priv_protocol || '',\n      });\n      context.grafana.notifySuccess(['Loaded', `Loaded device ${d.ip_address} (status: ${d.status}). Credential fields are left blank -- only fill them in if you want to change them.`]);\n    })\n    .catch((err) => {\n      context.grafana.notifyError(['Error', `Could not load device ${id}: ${err}`]);\n    });\n}"
      }
