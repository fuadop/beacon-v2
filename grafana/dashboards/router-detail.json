          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  i.\"ifDescr\"     AS `Interface`,\n  first_value(i.\"ifOperStatus\" order by i.time desc)  AS `Status`,   -- 1=up, 2=down\n  first_value(i.\"ifAdminStatus\" order by i.time desc) AS `Admin Status`,  -- 1=up, 2=down (administratively)\n  first_value(i.\"ifPhysAddress\" order by i.time desc) AS `MAC Address`,\n  first_value(ip.\"ipAdEntAddr\" order by i.time desc)  AS `IP Address`,\n  first_value(ip.\"ipAdEntNetMask\" order by i.time desc) AS `Subnet Mask`\nFROM interface i\nLEFT JOIN \"ipAddr\" ip\n  ON i.hostname = ip.hostname AND i.\"ifIndex\" = ip.\"ipAdEntIfIndex\"\nWHERE i.agent_host = '$loopback'\ngroup by i.\"ifDescr\"\norder by i.\"ifDescr\" asc",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ]
          }
        }
      ],
      "title": "Interfaces",
      "type": "table"
