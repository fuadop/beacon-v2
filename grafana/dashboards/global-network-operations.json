        {
          "dataset": "iox",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH deltas AS (\n  SELECT\n    hostname, \"ifIndex\", time,\n    \"ifInOctets\"  - LAG(\"ifInOctets\")  OVER (PARTITION BY hostname, \"ifIndex\" ORDER BY time) AS in_delta,\n    \"ifOutOctets\" - LAG(\"ifOutOctets\") OVER (PARTITION BY hostname, \"ifIndex\" ORDER BY time) AS out_delta\n  FROM interface\n)\nSELECT\n  date_bin(INTERVAL '1 minute', time) AS minute,\n  SUM(CASE WHEN in_delta  < 0 THEN in_delta  + 4294967296 ELSE in_delta  END) AS total_in_bytes,\n  SUM(CASE WHEN out_delta < 0 THEN out_delta + 4294967296 ELSE out_delta END) AS total_out_bytes\nFROM deltas\nWHERE time >= now() - INTERVAL '1 hour'\n  AND in_delta IS NOT NULL\nGROUP BY minute\nORDER BY minute;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ]
          }
        }
      ],
