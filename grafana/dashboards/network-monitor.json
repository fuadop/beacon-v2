        "update": {
          "method": "-",
          "url": "",
          "datasource": "",
          "header": [],
          "contentType": "application/json",
          "code": "const elements = context.panel.elements;\nconst get = (id) => {\n  const el = elements.find((e) => e.id === id);\n  return el && el.value !== undefined && el.value !== null ? el.value : '';\n};\n\nconst deviceId = get('device_id');\nconst isEdit = !!deviceId;\n\nconst payload = {\n  ip_address: get('ip_address'),\n  hostname: get('hostname'),\n  snmp_version: get('snmp_version'),\n  group_name: get('group_name'),\n  v3_user: get('v3_user'),\n  v3_auth_protocol: get('v3_auth_protocol'),\n  v3_priv_protocol: get('v3_priv_protocol'),\n};\n\n// Only send credential fields if the user actually typed something -- leaving\n// them blank while editing must not overwrite the stored credential.\nconst community = get('community');\nconst v3AuthKey = get('v3_auth_key');\nconst v3PrivKey = get('v3_priv_key');\nif (!isEdit || community) payload.community = community;\nif (!isEdit || v3AuthKey) payload.v3_auth_key = v3AuthKey;\nif (!isEdit || v3PrivKey) payload.v3_priv_key = v3PrivKey;\n\nconst url = isEdit ? `http://localhost:8080/devices/${deviceId}` : 'http://localhost:8080/devices';\nconst method = isEdit ? 'PATCH' : 'POST';\n\nfetch(url, {\n  method,\n  headers: { 'Content-Type': 'application/json' },\n  body: JSON.stringify(payload),\n})\n  .then(async (resp) => {\n    if (resp.ok) {\n      const body = await resp.json();\n      context.grafana.notifySuccess(['Saved', `Device ${body.ip_address} ${isEdit ? 'updated' : 'created'} -- status: ${body.status}.`]);\n      context.panel.initialRequest();\n    } else {\n      context.grafana.notifyError(['Error', `Failed to save device: HTTP ${resp.status}`]);\n    }\n  })\n  .catch((err) => {\n    context.grafana.notifyError(['Error', `Failed to save device: ${err}`]);\n  });",
          "highlight": false,
          "highlightColor": "red",
          "confirm": false,
          "payloadMode": "all",
          "getPayload": "return {}",
          "payload": {}
        },
