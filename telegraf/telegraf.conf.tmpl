[agent]
  interval = "{{.PollingIntervalSeconds}}s"
  round_interval = true
  metric_batch_size = 1000
  metric_buffer_limit = 10000
  flush_interval = "{{.PollingIntervalSeconds}}s"

[[outputs.influxdb_v2]]
  urls = ["{{.InfluxURL}}"]
  token = "{{.InfluxToken}}"
  organization = ""
  bucket = "{{.InfluxDatabase}}"
{{range .Devices}}
[[inputs.snmp]]
  # No name_override here: it overrides the measurement name for every metric
  # this plugin instance emits, including nested tables -- with it set, all of
  # interface/hrStorage/hrProcessor's data collapsed into one "snmp" measurement
  # instead of their own. Ad-hoc top-level fields (hostname, uptime) default to
  # "snmp" on their own; each [[inputs.snmp.table]] below keeps its own name.
  agents = ["udp://{{.IPAddress}}:161"]
  version = {{.VersionNumber}}
  timeout = "5s"
{{if eq .VersionNumber 3}}
  sec_name = "{{.V3User}}"
  sec_level = "{{.V3SecLevel}}"
  auth_protocol = "{{.V3AuthProtocol}}"
  auth_password = "{{.V3AuthPassword}}"
  priv_protocol = "{{.V3PrivProtocol}}"
  priv_password = "{{.V3PrivPassword}}"
{{else}}
  community = "{{.Community}}"
{{end}}
  [[inputs.snmp.field]]
    name = "hostname"
    oid = ".1.3.6.1.2.1.1.5.0"
    is_tag = true

  [[inputs.snmp.field]]
    name = "uptime"
    oid = ".1.3.6.1.2.1.1.3.0"

  # IF-MIB: per-interface traffic/error counters. Universally supported by
  # SNMP-enabled network gear, unlike the CPU/memory tables below.
  [[inputs.snmp.table]]
    name = "interface"
    inherit_tags = ["hostname"]
    oid = ".1.3.6.1.2.1.2.2"

    # Not marked is_tag: Telegraf 1.32.3 has been observed emitting is_tag
    # fields in *both* the tag-set and the field-set of the same line
    # (contrary to its own docs), which InfluxDB 3's per-column schema rejects
    # outright ("expected iox::column_type::tag, got iox::column_type::field").
    # A plain field works fine for our purposes (still queryable, still shows
    # up as a column) without hitting that conflict.
    [[inputs.snmp.table.field]]
      name = "ifDescr"
      oid = ".1.3.6.1.2.1.2.2.1.2"

    [[inputs.snmp.table.field]]
      name = "ifInOctets"
      oid = ".1.3.6.1.2.1.2.2.1.10"

    [[inputs.snmp.table.field]]
      name = "ifOutOctets"
      oid = ".1.3.6.1.2.1.2.2.1.16"

    [[inputs.snmp.table.field]]
      name = "ifInErrors"
      oid = ".1.3.6.1.2.1.2.2.1.14"

    [[inputs.snmp.table.field]]
      name = "ifOutErrors"
      oid = ".1.3.6.1.2.1.2.2.1.20"

  # IP-MIB ipAddrTable: maps IP addresses to interfaces. Indexed by the IP
  # itself (not ifIndex), so Telegraf auto-tags each row with ipAdEntAddr;
  # join to the interface table on (hostname, ifIndex = ipAdEntIfIndex) to
  # get an interface's IP alongside its name/status/MAC.
  [[inputs.snmp.table]]
    name = "ipAddr"
    inherit_tags = ["hostname"]
    oid = ".1.3.6.1.2.1.4.20"

    [[inputs.snmp.table.field]]
      name = "ipAdEntIfIndex"
      oid = ".1.3.6.1.2.1.4.20.1.2"

    [[inputs.snmp.table.field]]
      name = "ipAdEntNetMask"
      oid = ".1.3.6.1.2.1.4.20.1.3"

  # CISCO-PROCESS-MIB: CPU utilization. Cisco-proprietary (not part of any
  # standard/IETF MIB), confirmed against real Cisco IOS routers in this
  # deployment. Requires CISCO-SMI/CISCO-TC/CISCO-PROCESS-MIB bundled in
  # telegraf/mibs/ (sourced from https://github.com/cisco/cisco-mibs, the
  # official replacement for the decommissioned ftp.cisco.com MIB server) --
  # without them Telegraf can't initialize this table at all. Best-effort like
  # the HOST-RESOURCES-MIB tables below: non-Cisco gear just won't populate it.
  [[inputs.snmp.table]]
    name = "cpu"
    inherit_tags = ["hostname"]
    oid = ".1.3.6.1.4.1.9.9.109.1.1.1"

    [[inputs.snmp.table.field]]
      name = "cpu5sec"
      oid = ".1.3.6.1.4.1.9.9.109.1.1.1.1.6"

    [[inputs.snmp.table.field]]
      name = "cpu1min"
      oid = ".1.3.6.1.4.1.9.9.109.1.1.1.1.7"

    [[inputs.snmp.table.field]]
      name = "cpu5min"
      oid = ".1.3.6.1.4.1.9.9.109.1.1.1.1.8"

  # CISCO-MEMORY-POOL-MIB: memory pool usage. Cisco-proprietary, same
  # rationale/sourcing as the cpu table above (needs CISCO-SMI/CISCO-TC/
  # CISCO-MEMORY-POOL-MIB bundled in telegraf/mibs/). Confirmed against real
  # Cisco IOS routers: reports one row per memory pool (typically "Processor"
  # and "I/O"); ciscoMemoryPoolUsed + ciscoMemoryPoolFree = total pool size.
  [[inputs.snmp.table]]
    name = "memory"
    inherit_tags = ["hostname"]
    oid = ".1.3.6.1.4.1.9.9.48.1.1"

    # See the ifDescr comment above re: table fields + is_tag on this Telegraf version.
    [[inputs.snmp.table.field]]
      name = "ciscoMemoryPoolName"
      oid = ".1.3.6.1.4.1.9.9.48.1.1.1.2"

    [[inputs.snmp.table.field]]
      name = "ciscoMemoryPoolUsed"
      oid = ".1.3.6.1.4.1.9.9.48.1.1.1.5"

    [[inputs.snmp.table.field]]
      name = "ciscoMemoryPoolFree"
      oid = ".1.3.6.1.4.1.9.9.48.1.1.1.6"

    [[inputs.snmp.table.field]]
      name = "ciscoMemoryPoolLargestFree"
      oid = ".1.3.6.1.4.1.9.9.48.1.1.1.7"

  # HOST-RESOURCES-MIB: memory/CPU. Best-effort — routers/switches without an
  # embedded host-resources agent simply won't populate these fields; Telegraf
  # logs a per-field warning rather than failing the whole plugin.
  [[inputs.snmp.table]]
    name = "hrStorage"
    inherit_tags = ["hostname"]
    oid = ".1.3.6.1.2.1.25.2.3"

    # See the ifDescr comment above re: table fields + is_tag on this Telegraf version.
    [[inputs.snmp.table.field]]
      name = "hrStorageDescr"
      oid = ".1.3.6.1.2.1.25.2.3.1.3"

    [[inputs.snmp.table.field]]
      name = "hrStorageUsed"
      oid = ".1.3.6.1.2.1.25.2.3.1.6"

    [[inputs.snmp.table.field]]
      name = "hrStorageSize"
      oid = ".1.3.6.1.2.1.25.2.3.1.5"

  [[inputs.snmp.table]]
    name = "hrProcessor"
    inherit_tags = ["hostname"]
    oid = ".1.3.6.1.2.1.25.3.3"

    [[inputs.snmp.table.field]]
      name = "hrProcessorLoad"
      oid = ".1.3.6.1.2.1.25.3.3.1.2"
{{end}}
