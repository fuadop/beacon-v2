# --- InfluxDB 3 Core ---
INFLUXDB_URL=http://influxdb:8181
INFLUXDB_DATABASE=network_monitor
# Token for authenticating writes/queries against InfluxDB 3's HTTP API.
# Generate after first boot with: docker compose exec influxdb influxdb3 create token --admin
INFLUXDB_TOKEN=

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me

# --- Config API / Config Watcher / Trap Receiver ---
CONFIG_DB_PATH=/data/config.db
TRAPS_DB_PATH=/data/traps.db

# 32-byte key, hex-encoded (64 hex chars), used for AES-256-GCM credential encryption.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# How often (seconds) config-watcher polls SQLite for device/setting changes.
CONFIG_WATCHER_POLL_SECONDS=10

# Full container name of the telegraf service, used by config-watcher for
# `docker exec <name> kill -SIGHUP 1`. Leave unset — docker-compose.yml
# defaults it to "<this project's name>-telegraf-1" automatically. Only set
# this if you've renamed the service or changed container_name in
# docker-compose.yml.
TELEGRAF_CONTAINER_NAME=

# The IP address your monitored devices actually reach this machine on --
# e.g. what to configure as the destination in `snmp-server host <ip>` for
# traps. This can't be auto-detected: config-api runs in a container, which
# only ever sees its own docker-bridge IP, never the host's real interfaces.
# Find yours with `ifconfig`/`ipconfig getifaddr <interface>` on the host --
# if devices reach you over a VPN/tunnel, use that tunnel interface's IP, not
# your LAN IP. Exposed via config-api's GET /collector-ip.
COLLECTOR_IP=
