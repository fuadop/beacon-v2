          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "with inventory as (\n  select\n    first_value(hostname) as `Hostname`,\n    first_value(agent_host) as `IP Address`,\n    first_value(uptime order by time desc) as `UptimeMs` \n  from snmp group by agent_host\n),\nlatest_cpu as (\n  SELECT agent_host, first_value(cpu.cpu1min order by time desc) as cpu_utilization\n  from cpu group by agent_host\n)\nselect\n  'ONLINE' as `Status`,\n  `Hostname`, \n  `IP Address`,\n  concat(latest_cpu.cpu_utilization, '%') as `CPU`,\n  concat(\n    cast(((`UptimeMs` * 0.01) / 86400) as int),\n    'd ',\n    cast((((`UptimeMs` * 0.01) % 86400) / 3600) as int),\n    'h'\n  ) as `Uptime`\nfrom inventory\nleft join latest_cpu on latest_cpu.agent_host = inventory.`IP Address`\n\n",
          "refId": "A",
